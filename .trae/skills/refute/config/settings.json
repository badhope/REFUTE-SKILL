    "false_dichotomy": 1.1,
    "credentials_check": 1.4,
    "elder_supremacy": 1.2,
    "topic_hijack": 2.0,
    "concept_shift": 1.3,
    "rhetorical_question": 1.5,
    "red_herring": 1.6
  },

  "meme_dictionary": {
    "prefixes": [
      "笑死", "呵呵", "有没有一种可能",
      "不会吧不会吧", "就我一个人觉得吗",
      "说句不好听的", "不是我说你",
      "抛开事实不谈", "道理我都懂但是"
    ],
    "suffixes": [
      "你这么想也很正常", "懂的都懂",
